# Copy to .env.local and fill in. Required for AI prospect + coach debrief.
VITE_OPENAI_API_KEY=

# ── ElevenLabs voice (optional, better TTS than browser) ────────────
# Run the API alongside Vite: npm run dev:full
# Get keys/voice from elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Optional: defaults to eleven_turbo_v2_5
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# API port for this repo only (exl-latest uses 8787 — avoid clash locally / copied .env).
PORT=8788
